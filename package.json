{
  "name": "meridian-cards",
  "private": true,
  "type": "module",
  "version": "0.1.0",
  "scripts": {
    "postinstall": "wrangler types",
    "dev": "vite",
    "build": "vite build",
    "preview": "wrangler dev",
    "test": "vitest run --config vitest.config.ts && vitest run --config vitest.client.config.ts",
    "test:worker": "vitest run --config vitest.config.ts",
    "test:client": "vitest run --config vitest.client.config.ts",
    "lint": "biome check .",
    "format": "biome check --write .",
    "typecheck": "tsc -p tsconfig.json --noEmit && tsc -p tsconfig.worker.json --noEmit && tsc -p tsconfig.node.json --noEmit",
    "seed:gen": "tsx scripts/generate-seed.ts",
    "catalog:sync": "tsx scripts/sync-catalog.ts",
    "deploy": "vite build && wrangler deploy"
  },
  "dependencies": {
    "hono": "^4.6.0",
    "jose": "^5.9.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^7.2.0"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.4",
    "@cloudflare/vitest-pool-workers": "0.16.20",
    "@cloudflare/workers-types": "^4",
    "@testing-library/jest-dom": "^6.4.0",
    "@testing-library/react": "^16.0.0",
    "@types/node": "^26.0.1",
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.0",
    "autoprefixer": "^10.4.0",
    "jsdom": "^25.0.0",
    "postcss": "^8.4.0",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0",
    "vite": "^6.0.0",
    "vitest": "^4.1.0",
    "wrangler": "^4"
  }
}
